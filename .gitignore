# -------------------------- 通用 Node.js 忽略项 --------------------------
# 依赖包目录（核心！npm install 生成，无需上传）
node_modules/
# npm 日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# 包管理锁文件（可选忽略，建议保留，确保环境一致）
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# -------------------------- VitePress 专属忽略项 --------------------------
# VitePress 构建产物（部署脚本会生成，无需上传到 main 分支）
docs/.vitepress/dist/
# VitePress 缓存目录
docs/.vitepress/cache/
# Vite 开发服务器缓存
.vite/
# 临时预览目录
preview/

# -------------------------- 开发工具/系统忽略项 --------------------------
# IDE 配置文件（根据你的编辑器选择保留）
.idea/          # WebStorm/IDEA
.vscode/        # VS Code（若需共享配置，可删除此行）
*.suo           # Visual Studio
*.ntvs*
*.njsproj
*.sln
*.sw?           # Vim

# 系统临时文件
.DS_Store       # MacOS
Thumbs.db       # Windows
*.tmp
*.bak

# -------------------------- 其他可选忽略项 --------------------------
# 本地环境配置（若有）
.env
.env.local
.env.development.local
.env.production.local
# 测试相关
coverage/
*.log